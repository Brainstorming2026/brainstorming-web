---
import { Icon } from 'astro-icon/components'
import { solutions } from '@/data/solutions'
---

<section class="bg-gradient-to-b from-mist to-white">
  <div class="mx-auto max-w-[1512px] px-6 pb-16 pt-20 lg:px-24">
    <h1 class="mx-auto max-w-3xl text-center font-heading text-[28px] font-bold leading-tight text-dark sm:text-[35px] sm:leading-[42px]">
      A través de nuestras soluciones, podrás cumplir tus objetivos.
    </h1>

    <div class="mx-auto mt-14 grid max-w-[1140px] gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {solutions.map(solution => (
        <div id={solution.slug} class="relative scroll-mt-24 pb-6">
          <div class={`absolute inset-x-6 bottom-0 h-16 rounded-full opacity-40 blur-2xl ${solution.glowClass}`} aria-hidden="true" />
          <a
            href={solution.href ?? `#${solution.slug}`}
            class="relative flex h-full flex-col items-center rounded-[16px] bg-white px-6 py-10 text-center shadow-[0_10px_40px_rgba(0,0,0,0.06)] transition-shadow hover:shadow-[0_10px_40px_rgba(0,0,0,0.12)]"
          >
            <Icon name={solution.icon} class={`h-16 w-16 shrink-0 ${solution.colorClass}`} />
            <h2 class="mt-6 font-heading text-xl font-bold text-dark">
              {solution.title}
            </h2>
            <p class="mt-4 text-[15px] leading-6 text-dark-500">
              {solution.desc}
            </p>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="bg-gradient-to-t from-mist to-white">
  <div class="mx-auto max-w-[1140px] px-6 py-24 text-center lg:px-24">
    <h2 class="font-heading text-[28px] font-bold text-dark sm:text-[35px]">
      ¿Quieres conocer nuestros proyectos?
    </h2>
    <a
      href="/proyectos"
      class="mt-10 inline-flex items-center justify-center rounded-[10px] bg-primary px-8 py-3 font-heading text-sm font-bold text-white transition-colors hover:bg-primary-600"
    >
      VER PROYECTOS
    </a>
  </div>
</section>
