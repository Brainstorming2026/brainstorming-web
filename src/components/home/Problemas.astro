---
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import { problemaCards as cards } from '@/data'
import serviceUpBg from '@/assets/backgrounds/service-up-background.webp'
import serviceArrow from '@/assets/decorative/service-up-flecha.webp'
---

<section id="problemas" class="text-white">
  <!-- Ola superior: transparente arriba revela el hero blanco, navy abajo funde
       con la sección. El chevron se superpone al centro. -->
  <div class="relative">
    <Image
      src={serviceUpBg}
      alt=""
      aria-hidden="true"
      class="block w-full select-none"
    />
    <Image
      src={serviceArrow}
      alt=""
      aria-hidden="true"
      class="chevron-bob absolute left-1/2 top-[25%] w-12 select-none md:w-20"
    />
  </div>

  <div class="-mt-[2px] bg-gradient-to-b from-navy from-75% to-white">
    <div class="mx-auto max-w-[1512px] px-6 pb-30 pt-4 lg:px-24">
      <!-- Título -->
      <h2
        class="mx-auto max-w-4xl text-center font-heading text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl"
      >
        Comercializas servicios o productos pero no estás llegando a tus metas
        de ventas. ¿Por qué?
      </h2>

      <!-- Cards -->
      <div
        class="mt-16 grid gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-5"
      >
        {
          cards.map(card => (
            <div class="flex flex-col items-center text-center">
              <Icon name={card.icon} class="h-25 w-25" />
              <p class="mt-6 text-[15px] leading-6 text-white/90">{card.text}</p>
            </div>
          ))
        }
      </div>

      <!-- Cierre -->
      <div class="mt-16 flex flex-col items-center text-center">
        <h3 class="font-heading text-2xl font-bold sm:text-3xl">
          ¿Te suena familiar alguno de los puntos anteriores?
        </h3>
        <p class="mt-4 max-w-2xl text-[15px] leading-6 text-white/85">
          Si la respuesta es sí y quieres ver cómo podemos ayudarte, sigue
          leyendo y descubre más sobre cómo trabajamos.
        </p>
        <a
          href="#servicios"
          class="mt-8 rounded-[10px] bg-primary px-8 py-3 font-heading text-sm font-bold text-white transition-colors hover:bg-primary-600"
        >
          VER SERVICIOS
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Flecha con animación de "respiración" (bob vertical). Mantiene el centrado
     horizontal dentro del propio transform. */
  .chevron-bob {
    animation: chevron-bob 1.8s ease-in-out infinite;
  }
  @keyframes chevron-bob {
    0%,
    100% {
      transform: translate(-50%, 0);
    }
    50% {
      transform: translate(-50%, 8px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .chevron-bob {
      animation: none;
      transform: translateX(-50%);
    }
  }
</style>

