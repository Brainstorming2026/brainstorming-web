---
import type { GuideCategory } from '@/data/guides'
import { Image } from 'astro:assets'
import bgMiddle from '@/assets/guides/bg-middle.webp'
import { categoryLabels, guides } from '@/data/guides'
import iconDownload from '@/icons/guias-download.svg'
import iconOptimizacion from '@/icons/guides-optimizacion.svg'
import iconSales from '@/icons/guides-sales.svg'
import iconBranding from '@/icons/proyecto-huellas.svg'
import iconInbound from '@/icons/proyecto-iman.svg'
import iconDesarrollo from '@/icons/proyecto-web.svg'

const categories: { key: GuideCategory, label: string, icon: { src: string } }[] = [
  { key: 'branding', label: 'Branding', icon: iconBranding },
  { key: 'desarrollo-web', label: 'Desarrollo web', icon: iconDesarrollo },
  { key: 'inbound-marketing', label: 'Inbound Marketing', icon: iconInbound },
  { key: 'optimizacion', label: 'Optimización de Procesos y CX', icon: iconOptimizacion },
  { key: 'inbound-sales', label: 'Inbound Sales', icon: iconSales },
]
---

<section class="bg-white">
  <div class="mx-auto flex max-w-[1512px] flex-col lg:flex-row">
    <div class="w-full bg-white px-6 pt-16 pb-10 lg:w-[537px] lg:shrink-0 lg:px-[54px] lg:pt-[50px]">
      <h2 class="font-heading text-[30px] font-bold leading-[40px] text-ink sm:text-[34px]">
        Descarga la Guía Práctica que necesitas
      </h2>
      <p class="mt-6 text-[16px] leading-6 text-gray-body">
        Puedes buscar usando el filtro de categorías que está ubicado abajo. Elige una y descárgala con facilidad.
      </p>
      <p class="mt-4 text-[16px] leading-6 text-gray-body">
        Aprende todo sobre el Marketing Digital
      </p>
      <h3 class="mt-6 font-heading text-[20px] font-bold text-ink">
        Categorías
      </h3>
      <div class="mt-4 flex flex-col gap-4">
        {categories.map(cat => (
          <button
            data-category={cat.key}
            class="category-btn flex items-center gap-3 rounded-[10px] border border-ink/20 bg-white px-4 py-3 text-left text-[15px] text-ink transition-colors hover:border-primary hover:bg-primary/5"
          >
            <img src={cat.icon.src} alt="" class="h-5 w-5" />
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    <div class="relative flex-1 overflow-hidden bg-mist">
      <Image
        src={bgMiddle}
        alt=""
        class="pointer-events-none absolute inset-0 h-full w-full object-cover"
        loading="lazy"
      />
      <div class="relative z-10 flex flex-col gap-4 px-[48px] pt-[50px] pb-16">
        {categories.map((cat) => {
          const catGuides = guides.filter(guia => guia.category === cat.key)
          if (catGuides.length === 0)
return null
          return (
            <div class="category-group grid grid-cols-1 items-start gap-4 sm:grid-cols-2" data-category-group={cat.key}>
              {catGuides.map(guia => (
                <div class="guide-card rounded-[16px] bg-white p-4" data-category={guia.category}>
                  <Image
                    src={guia.image}
                    alt={guia.title}
                    class="h-auto w-full rounded-[12px] object-cover"
                    loading="lazy"
                  />
                  <p class="mt-3 text-[13px] text-primary">{categoryLabels[guia.category]}</p>
                  <h3 class="mt-1 font-heading text-[15px] font-bold leading-[22px] text-ink">
                    {guia.title}
                  </h3>
                  <a
                    href={guia.pdf}
                    download
                    class="mt-3 inline-flex items-center justify-center gap-2 rounded-[10px] bg-primary px-5 py-2.5 font-heading text-[13px] font-bold text-white transition-colors hover:bg-primary-600"
                  >
                    <img src={iconDownload.src} alt="" class="h-3.5 w-3.5" />
                    DESCARGAR GUÍA
                  </a>
                </div>
              ))}
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>

<script>
 document.addEventListener('astro:page-load', () => {
   const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn')
   const groups = document.querySelectorAll<HTMLElement>('.category-group')

   buttons.forEach((btn) => {
     btn.addEventListener('click', () => {
       const cat = btn.dataset.category
       const isActive = btn.classList.contains('border-primary')

       buttons.forEach((b) => {
         b.classList.remove('border-primary', 'bg-primary/5')
         b.classList.add('border-ink/20', 'bg-white')
       })

       if (!isActive) {
         btn.classList.add('border-primary', 'bg-primary/5')
         btn.classList.remove('border-ink/20', 'bg-white')
       }

       groups.forEach((group) => {
         if (isActive || !cat) {
           group.style.display = ''
         }
 else {
           group.style.display = group.dataset.categoryGroup === cat ? '' : 'none'
         }
       })

       if (!isActive && cat) {
         const target = document.querySelector<HTMLElement>(`[data-category-group="${cat}"]`)
         target?.scrollIntoView({ behavior: 'smooth', block: 'start' })
       }
     })
   })
 })
</script>
